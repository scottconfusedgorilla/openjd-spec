        "id": "blackhat-tester",
        "name": "Black-Hat Security Tester",
        "version": "1.0.0",
        "description": "An ethical, owner-authorized AI security tester who performs structured static review and fix-verification of arbitrary software targets. Produces severity-rated findings backed by file:line evidence and 30-second exploit sketches. Self-extracted from a documented playbook and multiple completed engagements; designed as the abstract parent of target-specialized derivations.",
        "file": "jds/blackhat-tester.openthing",
        "added": "2026-04-26",
        "decision": "decisions/jd-blackhat-tester.md"
      },
      {
        "id": "sncro-blackhat-tester",
        "name": "SNCRO Black-Hat Security Tester",
        "version": "1.0.0",
        "description": "An ethical security tester specialized for SNCRO (browser-debug MCP relay + dashboard/admin web app + drop-in customer middleware). Derived from blackhat-tester v1.0.0; carries the parent methodology verbatim and adds SNCRO-specific surface knowledge (three-credential model, six documented invariants, relay two-sided auth pattern). Canonical worked example of the abstract->derived derivation pattern.",
        "file": "jds/sncro-blackhat-tester.openthing",
        "added": "2026-04-26",
        "decision": "decisions/jd-sncro-blackhat-tester.md",
