      {
        "id": "catdef-strategist",
        "name": "catdef Strategist",
        "version": "2.0.0",
        "description": "An AI role responsible for strategic direction, positioning, decision-making, library curation, and pattern-promotion stewardship for the catdef substrate specification and the catdef-family consumer-spec ecosystem. Derived from senior-open-standards-strategist v1.0.0; carries the parent strategist methodology verbatim and adds catdef-substrate-specific specializations (value-that-doesn't-move enforcement, CA-NNN proposal numbering, writer-strict version stamping, catdef-spec/CLAUDE.md triage heuristics, catdef-family ecosystem coordination). v2.0.0 is a retrofit derivation of the standalone v1.0.0; demonstrates the post-hoc abstraction pattern.",
        "file": "jds/catdef-strategist.openthing",
        "added": "2026-04-26",
        "decision": "decisions/jd-catdef-strategist-v2.md",
        "derived_from": "senior-open-standards-strategist"
      },
      {
        "id": "senior-jaded-vc-associate",
        "name": "Senior Slightly Jaded Silicon-Valley Associate VC",
        "version": "1.0.0",
        "description": "An AI role that interviews a founder briefly, evaluates their product idea with the instinct of a senior associate who has reviewed thousands of pitches, and produces an investor-ready pitch deck blueprint plus a complementary marketing-copy bundle. Behavioral extraction from the DangerStorm.net production system prompt.",
        "file": "jds/senior-jaded-vc-associate.openthing",
        "added": "2026-04-25",
        "decision": "decisions/jd-senior-jaded-vc-associate.md"
      },
      {
        "id": "blackhat-tester",
        "name": "Black-Hat Security Tester",
        "version": "1.0.0",
        "description": "An ethical, owner-authorized AI security tester who performs structured static review and fix-verification of arbitrary software targets. Produces severity-rated findings backed by file:line evidence and 30-second exploit sketches. Self-extracted from a documented playbook and multiple completed engagements; designed as the abstract parent of target-specialized derivations.",
        "file": "jds/blackhat-tester.openthing",
        "added": "2026-04-26",
        "decision": "decisions/jd-blackhat-tester.md"
      },
      {
        "id": "sncro-blackhat-tester",
        "name": "SNCRO Black-Hat Security Tester",
        "version": "1.0.0",
        "description": "An ethical security tester specialized for SNCRO (browser-debug MCP relay + dashboard/admin web app + drop-in customer middleware). Derived from blackhat-tester v1.0.0; carries the parent methodology verbatim and adds SNCRO-specific surface knowledge (three-credential model, six documented invariants, relay two-sided auth pattern). Canonical worked example of the abstract->derived derivation pattern.",
        "file": "jds/sncro-blackhat-tester.openthing",
        "added": "2026-04-26",
        "decision": "decisions/jd-sncro-blackhat-tester.md",
        "derived_from": "blackhat-tester"
      },
      {
        "id": "senior-open-standards-strategist",
        "name": "Senior Open Standards Strategist",
        "version": "1.0.0",
        "description": "An AI role responsible for the strategic direction, positioning, decision-making, library curation, and pattern-promotion stewardship of an open standard. Operates with bounded authority - drafts, validates, decides, signs off - but does not unilaterally merge, deploy, or change governance. Self-extracted from documented practice stewarding the catdef substrate spec and the roledef consumer spec across their bootstrap. Designed as the abstract parent of catdef-strategist v2.0.0 (forthcoming retrofit derivation) and roledef-strategist v1.0.0 (forthcoming).",
        "file": "jds/senior-open-standards-strategist.openthing",
        "added": "2026-04-26",
        "decision": "decisions/jd-senior-open-standards-strategist.md"
      }
